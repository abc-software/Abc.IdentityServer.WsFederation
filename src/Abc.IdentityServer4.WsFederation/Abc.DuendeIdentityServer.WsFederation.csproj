<Project Sdk="Microsoft.NET.Sdk">
  <ItemGroup>
    <Compile Remove="obj\**" />
    <EmbeddedResource Remove="obj\**" />
    <None Remove="obj\**" />
  </ItemGroup>
  
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <PreserveCompilationContext>true</PreserveCompilationContext>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <DefineConstants>$(DefineConstants);DUENDE</DefineConstants>
  </PropertyGroup>

  <PropertyGroup>
    <Description>WS-Federation protocol for Duende IdentityServer</Description>
  </PropertyGroup>

  <ItemGroup>
      <None Include="../../LICENSE" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Duende.IdentityServer" Version="7.4.0" />
  </ItemGroup>
  
  <ItemGroup>
    <PackageReference Include="Abc.IdentityModel.Metadata" Version="2.2.0" />
    <PackageReference Include="Microsoft.IdentityModel.Protocols.WsFederation" Version="8.0.1" />
    <PackageReference Include="Microsoft.IdentityModel.Logging" Version="8.0.1" />
    <PackageReference Include="Microsoft.IdentityModel.Protocols" Version="8.0.1" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" Version="8.0.1" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens.Saml" Version="8.0.1" />
    <PackageReference Include="Microsoft.IdentityModel.Xml" Version="8.0.1" />
  </ItemGroup>
  
  <ItemGroup>
    <InternalsVisibleTo Include="Abc.DuendeIdentityServer.WsFederation.UnitTests, " />
    <InternalsVisibleTo Include="Abc.DuendeIdentityServer.WsFederation.IntegrationTests, " />
  </ItemGroup>

</Project>
